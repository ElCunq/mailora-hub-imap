  "query": "\n            SELECT e.id as \"id!\", e.direction as \"direction!\", e.mailbox as \"mailbox!\", \n                   e.actor, e.peer, e.subject, e.ts as \"ts!\"\n            FROM events e\n            JOIN user_accounts ua ON e.mailbox = ua.account_id\n            WHERE ua.user_id = ?\n            ORDER BY e.ts DESC\n            LIMIT 100\n            ",
